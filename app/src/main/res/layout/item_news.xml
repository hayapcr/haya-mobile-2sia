<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvNewsSite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Berita Desa"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/primaryGreen"
            android:background="#E8F5E9"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/tvNewsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pendataan Warga Penerima Bantuan Mulai Dilakukan"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvNewsSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Admin desa melakukan pendataan warga agar proses penyaluran bantuan sosial dapat berjalan lebih tepat sasaran."
            android:textSize="13sp"
            android:textColor="#555555"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginTop="6dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>