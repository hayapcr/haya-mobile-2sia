<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Pertemuan6.SixthActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="#D6E9DE"
        android:title="Pertemuan 6"
        android:titleTextColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- BUTTON 1 -->
    <Button
        android:id="@+id/btnFragment1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Home"
        android:layout_margin="8dp"
        android:backgroundTint="@color/primaryGreen"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnFragment2"
        app:layout_constraintHorizontal_chainStyle="spread"/>

    <!-- BUTTON 2 -->
    <Button
        android:id="@+id/btnFragment2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="About"
        android:layout_margin="8dp"
        android:backgroundTint="@color/primaryGreen"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toEndOf="@id/btnFragment1"
        app:layout_constraintEnd_toStartOf="@id/btnFragment3"/>

    <!-- BUTTON 3 -->
    <Button
        android:id="@+id/btnFragment3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Profile"
        android:layout_margin="8dp"
        android:backgroundTint="@color/primaryGreen"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toEndOf="@id/btnFragment2"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CONTAINER -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnFragment1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>