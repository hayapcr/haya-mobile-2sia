<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/secondaryColor">

    <!-- Header Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/softPink">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tvJudul"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/layanan"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/softPinkDark" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pilihan"
                android:textSize="14sp"
                android:textColor="@color/gray"
                android:layout_marginTop="6dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Service Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardCornerRadius="18dp"
        app:cardElevation="5dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="18dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:src="@drawable/logobunga"
                android:scaleType="centerCrop"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/deskCustom2"
                android:textSize="18sp"
                android:textColor="@color/textColor"
                android:lineSpacingExtra="5dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Button -->
    <Button
        android:id="@+id/btnKembali"
        android:layout_width="110dp"
        android:layout_height="42dp"
        android:text="Kembali"
        android:textStyle="bold"
        android:textSize="13sp"
        android:textColor="@color/softPinkDark"
        android:backgroundTint="@color/softPink"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp" />

</LinearLayout>