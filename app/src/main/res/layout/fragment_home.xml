<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/accentGreen">

    <!-- TOOLBAR -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primaryGreen"
        android:title="Home"
        android:titleTextColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SCROLL AREA -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/primaryGreen">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <!-- LOGO -->
                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/logobansos"
                        android:layout_marginBottom="16dp"/>

                    <!-- JUDUL -->
                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SIBANSOS"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <!-- DESKRIPSI -->
                    <TextView
                        android:id="@+id/tvDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Menu pembelajaran dan fitur aplikasi Bina Desa"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="24dp"/>

                    <!-- GRID LAYOUT -->
                    <androidx.gridlayout.widget.GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:columnCount="2"
                        app:useDefaultMargins="true">

                        <!-- CUSTOM 1 -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCustom1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Custom 1"
                            android:textAllCaps="false"
                            android:textColor="@color/primaryGreen"
                            app:icon="@drawable/ic_custom1"
                            app:iconSize="32dp"
                            app:iconTint="@color/primaryGreen"
                            app:iconGravity="textTop"
                            app:iconPadding="8dp"
                            app:cornerRadius="20dp"
                            app:backgroundTint="@color/white"
                            app:layout_columnWeight="1"
                            app:layout_gravity="fill_horizontal"/>

                        <!-- CUSTOM 2 -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCustom2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Custom 2"
                            android:textAllCaps="false"
                            android:textColor="@color/primaryGreen"
                            app:icon="@drawable/ic_custom2"
                            app:iconSize="32dp"
                            app:iconTint="@color/primaryGreen"
                            app:iconGravity="textTop"
                            app:iconPadding="8dp"
                            app:cornerRadius="20dp"
                            app:backgroundTint="@color/white"
                            app:layout_columnWeight="1"
                            app:layout_gravity="fill_horizontal"/>

                        <!-- RUMUS -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRumus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Rumus"
                            android:textAllCaps="false"
                            android:textColor="@color/primaryGreen"
                            app:icon="@drawable/ic_rumus"
                            app:iconSize="32dp"
                            app:iconTint="@color/primaryGreen"
                            app:iconGravity="textTop"
                            app:iconPadding="8dp"
                            app:cornerRadius="20dp"
                            app:backgroundTint="@color/white"
                            app:layout_columnWeight="1"
                            app:layout_gravity="fill_horizontal"/>

                        <!-- WEBVIEW -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnWebview"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="WebView"
                            android:textAllCaps="false"
                            android:textColor="@color/primaryGreen"
                            app:icon="@drawable/ic_webview"
                            app:iconSize="32dp"
                            app:iconTint="@color/primaryGreen"
                            app:iconGravity="textTop"
                            app:iconPadding="8dp"
                            app:cornerRadius="20dp"
                            app:backgroundTint="@color/white"
                            app:layout_columnWeight="1"
                            app:layout_gravity="fill_horizontal"/>


                    </androidx.gridlayout.widget.GridLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>